<!DOCTYPE html>
<html><head><title>CryptoBot v3</title>
<style>
body{background:#03080f;color:#c8dff0;font-family:monospace;padding:20px;}
h1{color:#f0a500;}
.stat{display:inline-block;padding:10px 20px;border:1px solid #122840;margin:5px;}
.green{color:#00ff9d;}.red{color:#ff3d5a;}
table{width:100%;border-collapse:collapse;margin-top:20px;}
th,td{padding:8px;border-bottom:1px solid #122840;text-align:left;font-size:11px;}
th{color:#f0a500;}
</style></head>
<body>
<h1>🤖 CryptoBot v3 Dashboard</h1>
<div id="stats">Loading...</div>
<h3>Recent Trades</h3>
<table id="trades"><thead><tr><th>Time</th><th>Mode</th><th>Symbol</th><th>Side</th><th>PnL</th><th>Status</th></tr></thead><tbody></tbody></table>
<script>
function refresh(){
  fetch('/api/stats').then(r=>r.json()).then(s=>{
    document.getElementById('stats').innerHTML=
      '<div class="stat">Total: '+s.total_trades+'</div>'+
      '<div class="stat">Open: '+s.open_trades+'</div>'+
      '<div class="stat green">Wins: '+s.wins+'</div>'+
      '<div class="stat red">Losses: '+s.losses+'</div>'+
      '<div class="stat">WR: '+s.win_rate+'%</div>'+
      '<div class="stat '+(s.total_pnl>=0?'green':'red')+'">PnL: $'+s.total_pnl.toFixed(2)+'</div>';
  });
  fetch('/api/trades').then(r=>r.json()).then(trades=>{
    var tb=document.querySelector('#trades tbody');
    tb.innerHTML=trades.map(t=>{
      var pnl=t.pnl||0;
      var c=pnl>=0?'green':'red';
      return '<tr><td>'+(t.timestamp||'').slice(11,16)+'</td><td>'+(t.mode||'spot').toUpperCase()+'</td><td>'+t.symbol+'</td><td>'+(t.side||'').toUpperCase()+'</td><td class="'+c+'">'+(t.status==='open'?'OPEN':pnl.toFixed(4))+'</td><td>'+t.status+'</td></tr>';
    }).join('');
  });
}
refresh();setInterval(refresh,5000);
</script>
</body></html>
