///     will be stored.
/// 
///     Example 1: Store vector<[16]xi8> horizontal (default) tile slice from tile at given index to memory.
///     ```mlir
///     arm_sme.store_tile_slice %tile, %tile_slice_index, %mask, %base[%c0] : vector<[16]x[16]xi8>, vector<[16]xi1>, memref<?x?xi8>
