    return ::mlir::failure();
  }
  if (or_maskAttr) result.getOrAddProperties<SwizzleBitModeOp::Properties>().or_mask = or_maskAttr;

  if (parser.parseCustomAttributeWithFallback(xor_maskAttr, parser.getBuilder().getIntegerType(32))) {
