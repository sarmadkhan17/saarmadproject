void MakeGatherDmaDescriptorOp::print(::mlir::OpAsmPrinter &_odsPrinter) {
  _odsPrinter << ' ';
  _odsPrinter << getBase();
  _odsPrinter << "[";
  _odsPrinter << getIndices();
  _odsPrinter << "]";
  _odsPrinter << ' ' << "globalSize";
  _odsPrinter << ' ';
  printDynamicIndexList(_odsPrinter, *this, getGlobalDynamicSizes(), getGlobalStaticSizesAttr());
  _odsPrinter << ' ' << "globalStride";
  _odsPrinter << ' ';
  printDynamicIndexList(_odsPrinter, *this, getGlobalDynamicStrides(), getGlobalStaticStridesAttr());
  _odsPrinter << ' ' << "sharedSize";
  _odsPrinter << ' ';
  printDynamicIndexList(_odsPrinter, *this, getSharedDynamicSizes(), getSharedStaticSizesAttr());
  if (getPadAmount()) {
    _odsPrinter << ' ' << "padShared";
    _odsPrinter << "(";
    if (::mlir::Value value = getPadAmount())
      _odsPrinter << value;
    _odsPrinter << ' ' << "every";
    _odsPrinter << ' ';
    if (::mlir::Value value = getPadInterval())
      _odsPrinter << value;
    _odsPrinter << ")";
  }
  if (getWorkgroupMask()) {
    _odsPrinter << ' ' << "workgroupMask";
    _odsPrinter << ' ';
    if (::mlir::Value value = getWorkgroupMask())
      _odsPrinter << value;
    if (getEarlyTimeout()) {
      _odsPrinter << ' ' << "earlyTimeout";
      _odsPrinter << ' ';
      if (::mlir::Value value = getEarlyTimeout())
        _odsPrinter << value;
    }
  }
  if (getAtomicBarrierAddress()) {
    _odsPrinter << ' ' << "atomicBarrier";
    _odsPrinter << "(";
    if (::mlir::Value value = getAtomicBarrierAddress())
      _odsPrinter << value;
    _odsPrinter << "[";
    _odsPrinter << getAtomicBarrierIndices();
    _odsPrinter << "]";
    _odsPrinter << ' ' << ":";
    _odsPrinter << ' ';
    _odsPrinter << (getAtomicBarrierAddress() ? ::llvm::ArrayRef<::mlir::Type>(getAtomicBarrierAddress().getType()) : ::llvm::ArrayRef<::mlir::Type>());
    _odsPrinter << ")";
  }
  if (getGlobalIncrement()) {
    _odsPrinter << ' ' << "iterate";
    _odsPrinter << ' ';
    if (::mlir::Value value = getGlobalIncrement())
      _odsPrinter << value;
    _odsPrinter << ",";
    _odsPrinter << ' ';
    if (::mlir::Value value = getLdsIncrement())
      _odsPrinter << value;
    _odsPrinter << ",";
    _odsPrinter << ' ';
    if (::mlir::Value value = getIterationCount())
      _odsPrinter << value;
  }
  ::llvm::SmallVector<::llvm::StringRef, 2> elidedAttrs;
  elidedAttrs.push_back("operandSegmentSizes");
  elidedAttrs.push_back("global_static_sizes");
  elidedAttrs.push_back("global_static_strides");
  elidedAttrs.push_back("shared_static_sizes");
  _odsPrinter.printOptionalAttrDict((*this)->getAttrs(), elidedAttrs);
  _odsPrinter << ' ' << ":";
  _odsPrinter << ' ';
   _odsPrinter << getBase().getType();
  _odsPrinter << ",";
  _odsPrinter << ' ';
  {
    auto type = getIndices().getType();
    if (auto validType = ::llvm::dyn_cast<::mlir::Type>(type))
      _odsPrinter.printStrippedAttrOrType(validType);
   else
     _odsPrinter << type;
  }
  _odsPrinter << ' ' << "->";
  _odsPrinter << ' ';
  _odsPrinter << getOperation()->getResultTypes();
}

