    result.getOrAddProperties<SparseMFMAOp::Properties>().m = mAttr;
    result.getOrAddProperties<SparseMFMAOp::Properties>().n = nAttr;
    result.getOrAddProperties<SparseMFMAOp::Properties>().k = kAttr;
  }

  sourceAOperandsLoc = parser.getCurrentLocation();
  if (parser.parseOperand(sourceARawOperand))
    return ::mlir::failure();
  if (parser.parseStar())
    return ::mlir::failure();

