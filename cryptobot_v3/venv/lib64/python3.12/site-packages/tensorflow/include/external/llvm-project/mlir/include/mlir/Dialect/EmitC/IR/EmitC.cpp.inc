  if (tblgen_template_args && !((::llvm::isa<::mlir::ArrayAttr>(tblgen_template_args))))
    return emitError(loc, "'emitc.call_opaque' op attribute 'template_args' failed to satisfy constraint: array attribute");
  return ::mlir::success();
}

