  if (!tblgen_b_elem_type) return emitError(loc, "'tt.dot_scaled' op requires attribute 'b_elem_type'");
  auto tblgen_fastMath = getProperties().fastMath; (void)tblgen_fastMath;
  if (!tblgen_fastMath) return emitError(loc, "'tt.dot_scaled' op requires attribute 'fastMath'");
  auto tblgen_lhs_k_pack = getProperties().lhs_k_pack; (void)tblgen_lhs_k_pack;
  auto tblgen_rhs_k_pack = getProperties().rhs_k_pack; (void)tblgen_rhs_k_pack;

  if (tblgen_a_elem_type && !((::llvm::isa<::mlir::triton::ScaleDotElemTypeAttr>(tblgen_a_elem_type))))
    return emitError(loc, "'tt.dot_scaled' op attribute 'a_elem_type' failed to satisfy constraint: allowed 32-bit signless integer cases: 0, 1, 2, 3, 4, 5, 6");

  if (tblgen_b_elem_type && !((::llvm::isa<::mlir::triton::ScaleDotElemTypeAttr>(tblgen_b_elem_type))))
    return emitError(loc, "'tt.dot_scaled' op attribute 'b_elem_type' failed to satisfy constraint: allowed 32-bit signless integer cases: 0, 1, 2, 3, 4, 5, 6");

  if (tblgen_fastMath && !((::llvm::isa<::mlir::BoolAttr>(tblgen_fastMath))))
    return emitError(loc, "'tt.dot_scaled' op attribute 'fastMath' failed to satisfy constraint: bool attribute");

  if (tblgen_lhs_k_pack && !((::llvm::isa<::mlir::BoolAttr>(tblgen_lhs_k_pack))))
    return emitError(loc, "'tt.dot_scaled' op attribute 'lhs_k_pack' failed to satisfy constraint: bool attribute");

  if (tblgen_rhs_k_pack && !((::llvm::isa<::mlir::BoolAttr>(tblgen_rhs_k_pack))))
    return emitError(loc, "'tt.dot_scaled' op attribute 'rhs_k_pack' failed to satisfy constraint: bool attribute");
