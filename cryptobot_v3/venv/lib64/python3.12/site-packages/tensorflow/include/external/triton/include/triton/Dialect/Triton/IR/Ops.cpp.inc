void DotScaledOp::print(::mlir::OpAsmPrinter &_odsPrinter) {
  _odsPrinter << ' ';
  _odsPrinter << getA();
  if (getAScale()) {
    _odsPrinter << ' ' << "scale";
    _odsPrinter << ' ';
    if (::mlir::Value value = getAScale())
      _odsPrinter << value;
  }
  _odsPrinter << ",";
  _odsPrinter << ' ';
  _odsPrinter << getB();
  if (getBScale()) {
    _odsPrinter << ' ' << "scale";
    _odsPrinter << ' ';
    if (::mlir::Value value = getBScale())
      _odsPrinter << value;
  }
  _odsPrinter << ",";
  _odsPrinter << ' ';
  _odsPrinter << getC();
  _odsPrinter << ' ' << "lhs";
  _odsPrinter << ' ' << "=";
  _odsPrinter << ' ';

  {
    auto caseValue = getAElemType();
    auto caseValueStr = stringifyScaleDotElemType(caseValue);
    _odsPrinter << caseValueStr;
  }
  _odsPrinter << ' ' << "rhs";
  _odsPrinter << ' ' << "=";
  _odsPrinter << ' ';

  {
    auto caseValue = getBElemType();
    auto caseValueStr = stringifyScaleDotElemType(caseValue);
    _odsPrinter << caseValueStr;
  }
  ::llvm::SmallVector<::llvm::StringRef, 2> elidedAttrs;
  elidedAttrs.push_back("operandSegmentSizes");
  elidedAttrs.push_back("a_elem_type");
  elidedAttrs.push_back("b_elem_type");
  {
     ::mlir::Builder odsBuilder(getContext());
     ::mlir::Attribute attr = getLhsKPackAttr();
     if(attr && (attr == odsBuilder.getBoolAttr(true)))
       elidedAttrs.push_back("lhs_k_pack");
  }
  {
     ::mlir::Builder odsBuilder(getContext());
     ::mlir::Attribute attr = getRhsKPackAttr();
     if(attr && (attr == odsBuilder.getBoolAttr(true)))
       elidedAttrs.push_back("rhs_k_pack");
  }
  _odsPrinter.printOptionalAttrDict((*this)->getAttrs(), elidedAttrs);
  _odsPrinter << ' ' << ":";
  _odsPrinter << ' ';
  {
    auto type = getA().getType();
    if (auto validType = ::llvm::dyn_cast<::mlir::RankedTensorType>(type))
      _odsPrinter.printStrippedAttrOrType(validType);
   else
     _odsPrinter << type;
  }
  if (getAScale()) {
    _odsPrinter << ",";
    _odsPrinter << ' ';
    _odsPrinter << (getAScale() ? ::llvm::ArrayRef<::mlir::Type>(getAScale().getType()) : ::llvm::ArrayRef<::mlir::Type>());
  }
  _odsPrinter << ' ' << "*";
  _odsPrinter << ' ';
  {
    auto type = getB().getType();
    if (auto validType = ::llvm::dyn_cast<::mlir::RankedTensorType>(type))
      _odsPrinter.printStrippedAttrOrType(validType);
   else
     _odsPrinter << type;
  }
  if (getBScale()) {
    _odsPrinter << ",";
    _odsPrinter << ' ';
    _odsPrinter << (getBScale() ? ::llvm::ArrayRef<::mlir::Type>(getBScale().getType()) : ::llvm::ArrayRef<::mlir::Type>());
  }
  _odsPrinter << ' ' << "->";
  _odsPrinter << ' ';
  {
    auto type = getD().getType();
    if (auto validType = ::llvm::dyn_cast<::mlir::RankedTensorType>(type))
      _odsPrinter.printStrippedAttrOrType(validType);
   else
     _odsPrinter << type;
  }
}

