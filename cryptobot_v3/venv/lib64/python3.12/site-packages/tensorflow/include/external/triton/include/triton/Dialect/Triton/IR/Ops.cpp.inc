      if (attr && ::mlir::failed(__mlir_ods_local_attr_constraint_TritonOps9(attr, "cache", emitError)))
        return ::mlir::failure();
    }

    {
      ::mlir::Attribute attr = attrs.get(getEvictAttrName(opName));
      if (attr && ::mlir::failed(__mlir_ods_local_attr_constraint_TritonOps10(attr, "evict", emitError)))
        return ::mlir::failure();
