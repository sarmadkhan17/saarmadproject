::llvm::LogicalResult DotScaledOpAdaptor::verify(::mlir::Location loc) {
  auto tblgen_a_elem_type = getProperties().a_elem_type; (void)tblgen_a_elem_type;
  if (!tblgen_a_elem_type) return emitError(loc, "'tt.dot_scaled' op requires attribute 'a_elem_type'");
