        return ::mlir::failure();
    }

    {
      ::mlir::Attribute attr = attrs.get(getLayoutCdAttrName(opName));
      if (attr && ::mlir::failed(__mlir_ods_local_attr_constraint_XeGPU3(attr, "layout_cd", emitError)))
        return ::mlir::failure();
    }
    return ::mlir::success();
}

::llvm::LogicalResult DpasOp::readProperties(::mlir::DialectBytecodeReader &reader, ::mlir::OperationState &state) {
