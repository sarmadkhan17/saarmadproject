      }
    }
  }

  {
    auto &propStorage = prop.subgroup_block_io;
       auto attr = dict.get("subgroup_block_io");
    if (attr) {
      auto convertedAttr = ::llvm::dyn_cast<std::remove_reference_t<decltype(propStorage)>>(attr);
